<#
.SYNOPSIS
    Secure Boot Readiness Checker

.VERSION
    1.7

.AUTHOR
    Lijane Consulting
#>

[CmdletBinding()]
param(
    [switch]$Detailed,
    [switch]$ExportJson,
    [switch]$ExportHtml,
    [switch]$CheckEvents,
    [switch]$Quiet,
    [switch]$ExportCsv,
    [string]$OutputPath = $PSScriptRoot
)

function Get-AsciiString {
    param([byte[]]$Bytes)

    try {
        return [System.Text.Encoding]::ASCII.GetString($Bytes)
    }
    catch {
        return ""
    }
}

function Find-CertificateName {
    param(
        [string]$Content,
        [string[]]$Patterns
    )

    foreach ($Pattern in $Patterns) {
        if ($Content -match [regex]::Escape($Pattern)) {
            return $Pattern
        }
    }

    return $null
}

function Get-ReadinessRecommendation {
    param(
        [bool]$IsUEFI,
        [bool]$SecureBootEnabled,
        [bool]$HasKEK2023,
        [bool]$HasDB2023,
        [bool]$HasDBX
    )

    if (-not $IsUEFI) {
        return "Legacy BIOS or unsupported platform. Exclude this device from Secure Boot 2023 remediation scope."
    }

    if (-not $SecureBootEnabled) {
        return "Secure Boot is disabled. Review BIOS/UEFI configuration before deploying Secure Boot 2023 updates."
    }

    if (-not $HasKEK2023) {
        return "Microsoft KEK 2023 is missing. Deploy Secure Boot 2023 update enablement."
    }

    if (-not $HasDB2023) {
        return "Microsoft DB 2023 is missing. Device may require additional Secure Boot update steps."
    }

    if (-not $HasDBX) {
        return "DBX appears empty or unreadable. Validate firmware and Secure Boot variable access."
    }

    return "No action required. Device is ready for Secure Boot 2026 requirements."
}

Write-Host ""
Write-Host "==================================================" -ForegroundColor Cyan
Write-Host " Secure Boot Readiness Checker v1.1" -ForegroundColor Cyan
Write-Host " Lijane Consulting" -ForegroundColor Cyan
Write-Host "==================================================" -ForegroundColor Cyan
Write-Host ""

$ComputerSystem = Get-CimInstance Win32_ComputerSystem
$BIOS = Get-CimInstance Win32_BIOS
$OS = Get-CimInstance Win32_OperatingSystem

$Manufacturer = $ComputerSystem.Manufacturer
$Model = $ComputerSystem.Model
$BIOSVersion = $BIOS.SMBIOSBIOSVersion
$BIOSDate = $BIOS.ReleaseDate
$OSVersion = $OS.Version
$OSBuild = $OS.BuildNumber

$IsUEFI = $false
$SecureBootEnabled = $false
$UnsupportedReason = $null

try {
    $SecureBootEnabled = Confirm-SecureBootUEFI -ErrorAction Stop
    $IsUEFI = $true
}
catch {
    $UnsupportedReason = $_.Exception.Message
    $IsUEFI = $false
    $SecureBootEnabled = $false
}

$HasKEK2023 = $false
$HasDB2023 = $false
$HasDBX = $false

$DetectedKEK2023 = $null
$DetectedDB2023 = $null

$KEKAscii = ""
$DBAscii = ""
$DBXBytesCount = 0

$KEKPatterns = @(
    "Microsoft Corporation KEK 2K CA 2023"
)

$DBPatterns = @(
    "Microsoft Windows UEFI CA 2023",
    "Windows UEFI CA 2023",
    "Microsoft UEFI CA 2023"
)

if ($IsUEFI) {
    try {
        $KEK = Get-SecureBootUEFI KEK -ErrorAction Stop
        $DB = Get-SecureBootUEFI db -ErrorAction Stop
        $DBX = Get-SecureBootUEFI dbx -ErrorAction Stop

        $KEKAscii = Get-AsciiString -Bytes $KEK.Bytes
        $DBAscii = Get-AsciiString -Bytes $DB.Bytes
        $DBXBytesCount = $DBX.Bytes.Count

        $DetectedKEK2023 = Find-CertificateName -Content $KEKAscii -Patterns $KEKPatterns
        $DetectedDB2023 = Find-CertificateName -Content $DBAscii -Patterns $DBPatterns

        $HasKEK2023 = [bool]$DetectedKEK2023
        $HasDB2023 = [bool]$DetectedDB2023
        $HasDBX = ($DBXBytesCount -gt 0)
    }
    catch {
        $UnsupportedReason = $_.Exception.Message
    }
}

$Score = 0

if ($IsUEFI) { $Score += 20 }
if ($SecureBootEnabled) { $Score += 20 }
if ($HasKEK2023) { $Score += 20 }
if ($HasDB2023) { $Score += 20 }
if ($HasDBX) { $Score += 20 }

if (-not $IsUEFI) {
    $Status = "UNSUPPORTED"
}
elseif ($Score -ge 90) {
    $Status = "READY"
}
elseif ($Score -ge 60) {
    $Status = "READY WITH WARNING"
}
else {
    $Status = "ACTION REQUIRED"
}

$Recommendation = Get-ReadinessRecommendation `
    -IsUEFI $IsUEFI `
    -SecureBootEnabled $SecureBootEnabled `
    -HasKEK2023 $HasKEK2023 `
    -HasDB2023 $HasDB2023 `
    -HasDBX $HasDBX

Write-Host "Computer Name : $env:COMPUTERNAME"
Write-Host "Manufacturer  : $Manufacturer"
Write-Host "Model         : $Model"
Write-Host "BIOS Version  : $BIOSVersion"
Write-Host "BIOS Date     : $BIOSDate"
Write-Host "OS Version    : $OSVersion"
Write-Host "OS Build      : $OSBuild"
Write-Host ""

Write-Host "UEFI Mode     : $IsUEFI"
Write-Host "Secure Boot   : $SecureBootEnabled"
Write-Host "KEK 2023      : $HasKEK2023"
Write-Host "DB 2023       : $HasDB2023"
Write-Host "DBX Present   : $HasDBX"
Write-Host ""

Write-Host "Status        : $Status"
Write-Host "Score         : $Score / 100"
Write-Host ""

Write-Host "Recommendation:"
Write-Host "$Recommendation"
Write-Host ""

$LastSecureBootEventId = $null
$LastSecureBootEventDate = $null
$LastSecureBootEventMessage = $null
$SecureBootEventStatus = "Not checked"

if ($CheckEvents) {
    try {
        $Events = Get-WinEvent -LogName "Microsoft-Windows-TPM-WMI/Operational" `
            -FilterXPath "*[System[(EventID=1795 or EventID=1796 or EventID=1801 or EventID=1808)]]" `
            -MaxEvents 20 `
            -ErrorAction Stop

        if ($Events) {
            $LastEvent = $Events | Sort-Object TimeCreated -Descending | Select-Object -First 1

            $LastSecureBootEventId = $LastEvent.Id
            $LastSecureBootEventDate = $LastEvent.TimeCreated
            $LastSecureBootEventMessage = $LastEvent.Message

            $SecureBootEventStatus = switch ($LastEvent.Id) {
                1808 { "Secure Boot update appears successfully applied." }
                1795 { "Secure Boot update detected or initiated." }
                1796 { "Secure Boot update warning or issue detected." }
                1801 { "Secure Boot update issue detected." }
                default { "Secure Boot related event detected." }
            }
        }
        else {
            $SecureBootEventStatus = "No Secure Boot related TPM-WMI event found."
        }
    }
    catch {
    if ($_.Exception.Message -match "There is not an event log") {
        $SecureBootEventStatus = "TPM-WMI event log not available on this device."
        $LastSecureBootEventId = $null
        $LastSecureBootEventDate = $null
        $LastSecureBootEventMessage = $null
    }
    else {
        $SecureBootEventStatus = "Unable to read TPM-WMI events: $($_.Exception.Message)"
    }
}
}


if ($Detailed) {
    Write-Host "Detailed Information"
    Write-Host "--------------------"

    Write-Host "Detected KEK 2023 : $DetectedKEK2023"
    Write-Host "Detected DB 2023  : $DetectedDB2023"
    Write-Host "DBX Bytes Count   : $DBXBytesCount"

    if ($UnsupportedReason) {
        Write-Host "Last Error        : $UnsupportedReason"
    }

    Write-Host ""
}

if ($CheckEvents) {
    Write-Host "Secure Boot Events"
    Write-Host "------------------"
    Write-Host "Last Event ID   : $LastSecureBootEventId"
    Write-Host "Last Event Date : $LastSecureBootEventDate"
    Write-Host "Event Status    : $SecureBootEventStatus"
    Write-Host ""
}

$Result = [PSCustomObject]@{
    ComputerName                 = $env:COMPUTERNAME
    Manufacturer                 = $Manufacturer
    Model                        = $Model
    BIOSVersion                  = $BIOSVersion
    BIOSDate                     = $BIOSDate
    OSVersion                    = $OSVersion
    OSBuild                      = $OSBuild

    IsUEFI                       = $IsUEFI
    SecureBootEnabled            = $SecureBootEnabled
    KEK2023Present               = $HasKEK2023
    DB2023Present                = $HasDB2023
    DBXPresent                   = $HasDBX

    DetectedKEK2023              = $DetectedKEK2023
    DetectedDB2023               = $DetectedDB2023
    DBXBytesCount                = $DBXBytesCount

    CheckEvents                  = $CheckEvents
    LastSecureBootEventId        = $LastSecureBootEventId
    LastSecureBootEventDate      = $LastSecureBootEventDate
    SecureBootEventStatus        = $SecureBootEventStatus
    LastSecureBootEventMessage   = $LastSecureBootEventMessage

    Score                        = $Score
    Status                       = $Status
    Recommendation               = $Recommendation
    LastError                    = $UnsupportedReason
    ScanDate                     = (Get-Date).ToString("s")
}

if ($ExportJson) {
    if (-not (Test-Path $OutputPath)) {
        New-Item -Path $OutputPath -ItemType Directory -Force | Out-Null
    }

    $Timestamp = Get-Date -Format "yyyyMMdd-HHmmss"
    $JsonFile = Join-Path $OutputPath "SecureBootReadiness_$env:COMPUTERNAME`_$Timestamp.json"

    $Result | ConvertTo-Json -Depth 5 | Out-File -FilePath $JsonFile -Encoding UTF8

    if (-not $Quiet) {
        Write-Host "JSON Export    : $JsonFile"
    }
}

if ($ExportCsv) {
    if (-not (Test-Path $OutputPath)) {
        New-Item -Path $OutputPath -ItemType Directory -Force | Out-Null
    }

    $Timestamp = Get-Date -Format "yyyyMMdd-HHmmss"
    $CsvFile = Join-Path $OutputPath "SecureBootReadiness_$env:COMPUTERNAME`_$Timestamp.csv"

    $Result | Export-Csv -Path $CsvFile -NoTypeInformation -Encoding UTF8

    if (-not $Quiet) {
        Write-Host "CSV Export     : $CsvFile"
    }
}

if ($ExportHtml) {

    if (-not (Test-Path $OutputPath)) {
        New-Item -Path $OutputPath -ItemType Directory -Force | Out-Null
    }

    $Timestamp = Get-Date -Format "yyyyMMdd-HHmmss"
    $HtmlFile = Join-Path $OutputPath "SecureBootReadiness_$env:COMPUTERNAME`_$Timestamp.html"

    $StatusClass = switch ($Status) {
        "READY" { "ready" }
        "READY WITH WARNING" { "warning" }
        "ACTION REQUIRED" { "action" }
        "UNSUPPORTED" { "unsupported" }
        default { "unknown" }
    }

    $HtmlContent = @"
<!DOCTYPE html>
<html>
<head>
<meta charset="UTF-8">
<title>Secure Boot Readiness Report</title>
<style>
body { font-family: Segoe UI, Arial; background:#f4f6f8; color:#1f2937; margin:0; }
.header { background:#0f172a; color:white; padding:24px 40px; }
.header h1 { margin:0; font-size:24px; }
.header p { margin:6px 0 0 0; color:#cbd5e1; }
.container { padding:30px 40px; }
.card { background:white; border-radius:10px; padding:22px; margin-bottom:20px; box-shadow:0 2px 8px rgba(0,0,0,0.08); }
.status { font-size:28px; font-weight:700; padding:14px 18px; border-radius:8px; display:inline-block; }
.ready { background:#dcfce7; color:#166534; }
.warning { background:#fef9c3; color:#854d0e; }
.action { background:#fee2e2; color:#991b1b; }
.unsupported { background:#e5e7eb; color:#374151; }
.unknown { background:#e0e7ff; color:#3730a3; }
.score { font-size:42px; font-weight:700; margin-top:10px; }
.grid { display:grid; grid-template-columns: 260px 1fr; row-gap:10px; }
.label { font-weight:600; color:#475569; }
.ok { color:#166534; font-weight:700; }
.ko { color:#991b1b; font-weight:700; }
.footer { color:#64748b; font-size:12px; margin-top:30px; }
</style>
</head>
<body>

<div class="header">
  <h1>Secure Boot Readiness Checker</h1>
  <p>Lijane Consulting - Digital Workplace & Endpoint Security</p>
</div>

<div class="container">

  <div class="card">
    <div class="status $StatusClass">$Status</div>
    <div class="score">$Score / 100</div>
    <p>$Recommendation</p>
  </div>

  <div class="card">
    <h2>Device Information</h2>
    <div class="grid">
      <div class="label">Computer Name</div><div>$env:COMPUTERNAME</div>
      <div class="label">Manufacturer</div><div>$Manufacturer</div>
      <div class="label">Model</div><div>$Model</div>
      <div class="label">BIOS Version</div><div>$BIOSVersion</div>
      <div class="label">BIOS Date</div><div>$BIOSDate</div>
      <div class="label">OS Version</div><div>$OSVersion</div>
      <div class="label">OS Build</div><div>$OSBuild</div>
    </div>
  </div>

  <div class="card">
    <h2>Secure Boot Checks</h2>
    <div class="grid">
      <div class="label">UEFI Mode</div><div>$IsUEFI</div>
      <div class="label">Secure Boot Enabled</div><div>$SecureBootEnabled</div>
      <div class="label">KEK 2023 Present</div><div>$HasKEK2023</div>
      <div class="label">DB 2023 Present</div><div>$HasDB2023</div>
      <div class="label">DBX Present</div><div>$HasDBX</div>
    </div>
  </div>

  <div class="card">
    <h2>Detected Certificates</h2>
    <div class="grid">
      <div class="label">Detected KEK 2023</div><div>$DetectedKEK2023</div>
      <div class="label">Detected DB 2023</div><div>$DetectedDB2023</div>
      <div class="label">DBX Bytes Count</div><div>$DBXBytesCount</div>
      <div class="label">Last Error</div><div>$UnsupportedReason</div>
    </div>
  </div>
  <div class="card">
  <h2>Secure Boot Events</h2>
  <div class="grid">
    <div class="label">Check Events</div><div>$CheckEvents</div>
    <div class="label">Last Event ID</div><div>$LastSecureBootEventId</div>
    <div class="label">Last Event Date</div><div>$LastSecureBootEventDate</div>
    <div class="label">Event Status</div><div>$SecureBootEventStatus</div>
  </div>
</div>

  <div class="footer">
    Report generated on $(Get-Date -Format "yyyy-MM-dd HH:mm:ss") by Lijane Consulting.
  </div>

</div>
</body>
</html>
"@

    $HtmlContent | Out-File -FilePath $HtmlFile -Encoding UTF8

    Write-Host "HTML Export    : $HtmlFile"
}

$ExitCode = switch ($Result.Status) {
    "READY" { 0 }
    "READY WITH WARNING" { 1 }
    "ACTION REQUIRED" { 2 }
    "UNSUPPORTED" { 3 }
    default { 9 }
}

if ($Quiet) {
    Write-Output "$($Result.Status);Score=$($Result.Score);KEK2023=$($Result.KEK2023Present);DB2023=$($Result.DB2023Present);DBX=$($Result.DBXPresent)"
    exit $ExitCode
}

exit 0

Write-Host "=================================================="
